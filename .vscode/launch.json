{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug on FuS Board",
            "type": "cppdbg",
            "request": "launch",
            "program": "${config:FUS.BINARY_DIR}/${config:FUS.APP_NAME}",
            "args": [
                "-u",
                "-m",
            ],
            "cwd": "${workspaceFolder}",
            "environment": [],
            "targetArchitecture": "${config:FUS.BOARD_ARCH}",
            "preLaunchTask": "fus_debug-on-board",
            "externalConsole":false,
            "MIMode": "${config:FUS.MIMODE}",
            "miDebuggerPath": "${config:FUS.DEBUGGER_PATH}",
            "miDebuggerArgs":"${config:FUS.DEBUGGER_ARGS}",
            "miDebuggerServerAddress": "${config:FUS.BOARD_IP}:${config:FUS.DEBUG_PORT}",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set remote sysroot for shared libraries",
                    "text": "set sysroot /home/developer/fsimx6sx-B2019.11/build/buildroot-2019.05.1-fsimx6sx-B2019.11/output/host/arm-buildroot-linux-gnueabihf/sysroot",
                    "ignoreFailures": false
                }
            ],
            "stopAtEntry": true,
        },
    ]
}
